{
  "name": "alembic-graph",
  "displayName": "Alembic Graph",
  "description": "Interactive graph of your Alembic migration history — visualize heads, merges, and broken links; drag to merge heads or repair broken down_revisions.",
  "publisher": "OmniaInc",
  "version": "0.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HelicopterHelicopter/alembic-graph-extension.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "media/icon.png",
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/alembic.ini"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "alembicGraph",
          "title": "Alembic Migrations",
          "icon": "media/alembic.svg"
        }
      ]
    },
    "views": {
      "alembicGraph": [
        {
          "type": "webview",
          "id": "alembicGraph.sidebar",
          "name": "Alembic Migrations"
        }
      ]
    },
    "commands": [
      {
        "command": "alembicGraph.openGraph",
        "title": "Open Migration Graph",
        "category": "Alembic Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "alembicGraph.refresh",
        "title": "Refresh",
        "category": "Alembic Graph",
        "icon": "$(refresh)"
      },
      {
        "command": "alembicGraph.upgradeHead",
        "title": "Upgrade to Head",
        "category": "Alembic Graph"
      },
      {
        "command": "alembicGraph.mergeHeads",
        "title": "Merge Heads…",
        "category": "Alembic Graph"
      },
      {
        "command": "alembicGraph.selectProject",
        "title": "Select Alembic Project…",
        "category": "Alembic Graph"
      },
      {
        "command": "alembicGraph.showInGraph",
        "title": "Show in Migration Graph",
        "category": "Alembic Graph"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "alembicGraph.openGraph",
          "when": "view == alembicGraph.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "alembicGraph.refresh",
          "when": "view == alembicGraph.sidebar",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Alembic Graph",
      "properties": {
        "alembicGraph.laneColorA": {
          "type": "string",
          "default": "#4aa3ff",
          "description": "Color of the trunk lane (lane 0)."
        },
        "alembicGraph.laneColorB": {
          "type": "string",
          "default": "#c586c0",
          "description": "Color of branch lanes."
        },
        "alembicGraph.showSqlPreview": {
          "type": "boolean",
          "default": true,
          "description": "Show upgrade()/downgrade() bodies in the revision detail panel."
        },
        "alembicGraph.alembicCommand": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Override the alembic executable (default: selected Python interpreter → `python -m alembic`, else `alembic` on PATH)."
        },
        "alembicGraph.environmentFile": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Optional `.env` file loaded for Alembic subprocesses. Relative paths resolve from `alembic.ini`; supports `~`, `${workspaceFolder}`, `${gitMainWorktree}`, and `${gitMainProject}`. Existing process variables take precedence."
        },
        "alembicGraph.pythonEnvironmentPath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Optional virtual-environment directory or Python executable used for Alembic. Relative paths resolve from `alembic.ini`; supports `~`, `${workspaceFolder}`, `${gitMainWorktree}`, and `${gitMainProject}`."
        },
        "alembicGraph.collapseThreshold": {
          "type": "number",
          "default": 20,
          "minimum": 3,
          "description": "Minimum run of linear revisions at the root end to collapse."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "check": "tsc --noEmit -p . && tsc --noEmit -p src/webview",
    "commitlint": "commitlint",
    "release": "semantic-release",
    "test:unit": "vitest run",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^20",
    "@types/vscode": "1.90.0",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "esbuild": "^0.25",
    "semantic-release": "^25.0.8",
    "semantic-release-vsce": "^6.1.5",
    "typescript": "^5",
    "vitest": "^3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
